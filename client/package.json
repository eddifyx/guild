{
  "name": "guild",
  "productName": "guild",
  "version": "1.0.72",
  "private": true,
  "description": "/guild encrypted messenger",
  "author": "/guild",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "test:stabilization": "node ../scripts/run-stabilization-tests.mjs",
    "make:mac-release": "GUILD_MAC_SIGN=1 electron-forge make --platform=darwin --arch=arm64",
    "make:mac-dmg": "bash scripts/build-mac-dmg.sh",
    "create:release-proof": "python3 ../scripts/create-release-proof.py",
    "verify:mac-release": "node scripts/verify-mac-release-env.js",
    "verify:client-version": "node ../scripts/validate-client-version.mjs ../server/client-version.json",
    "verify:release-proof": "python3 ../scripts/validate-release-proof.py",
    "verify:packaged-runtime": "bash ../scripts/validate-packaged-runtime.sh",
    "verify:mac-update-zip": "bash ../scripts/validate-mac-update-zip.sh",
    "verify:windows-update-zip": "bash ../scripts/validate-windows-update-zip.sh",
    "verify:lane-markers": "bash ../scripts/verify-lane-markers.sh"
  },
  "dependencies": {
    "@noble/ciphers": "^1.2.0",
    "@noble/curves": "^1.8.0",
    "@noble/hashes": "^1.7.0",
    "@sapphi-red/web-noise-suppressor": "^0.3.5",
    "@signalapp/libsignal-client": "^0.88.1",
    "better-sqlite3": "^12.6.2",
    "date-fns": "^3.3.1",
    "deepfilternet3-noise-filter": "^1.2.1",
    "geist": "^1.7.0",
    "mediasoup-client": "^3.18.7",
    "nostr-tools": "^2.23.2",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io-client": "^4.7.4"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.2.0",
    "@electron-forge/maker-deb": "^7.2.0",
    "@electron-forge/maker-dmg": "^7.2.0",
    "@electron-forge/maker-zip": "^7.2.0",
    "@electron-forge/plugin-vite": "^7.2.0",
    "@electron/rebuild": "^3.7.2",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.3.3",
    "vite": "^5.1.0"
  }
}
