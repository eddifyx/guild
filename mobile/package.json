{
  "name": "guild-mobile",
  "version": "1.0.73",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:ios:testflight": "eas build --platform ios --profile testflight",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:zapstore": "eas build --platform android --profile zapstore",
    "submit:ios:testflight": "eas submit --platform ios --profile testflight",
    "publish:zapstore": "zsp publish --wizard"
  },
  "dependencies": {
    "expo": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-secure-store": "~55.0.11",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "nostr-tools": "^2.23.2",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-get-random-values": "~1.11.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eas-cli": "^18.5.0",
    "typescript": "~5.9.2"
  }
}
