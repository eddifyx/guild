+    'node-gyp-build',
+    'uuid',
+    'type-fest',
+    'bindings',
+    'file-uri-to-path',
+  ];
+
+  for (const dep of packages) {
+    const src = path.join(rootModules, dep);
+    const dest = path.join(vendorModulesDir, dep);
+    if (fs.existsSync(src)) {
+      copyDirSync(src, dest);
+    }
+  }
+}
