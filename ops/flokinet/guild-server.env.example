NODE_ENV=production
PORT=3001

# Optional: enable native HTTPS directly in the Node server.
# If you terminate TLS at Caddy or another reverse proxy, leave these unset.
# TLS_KEY_PATH=/etc/ssl/private/guild.key
# TLS_CERT_PATH=/etc/ssl/certs/guild.crt
# TLS_CA_PATH=/etc/ssl/certs/guild-chain.crt
# HTTP_REDIRECT_PORT=80

# Required for mediasoup clients outside localhost.
ANNOUNCED_IP=203.0.113.10

# Production RTP range when sharing the same host with staging.
MEDIASOUP_RTC_MIN_PORT=10000
MEDIASOUP_RTC_MAX_PORT=10100

# Add the HTTPS origins you expect browser traffic from.
# Electron file:// traffic is already accepted by the server.
ALLOWED_ORIGINS=https://guild.app,https://www.guild.app

# Optional: tighten once you have real traffic data.
GLOBAL_RL_MAX=1000

# Required before exposing the dev dashboard anywhere beyond localhost.
DEV_DASHBOARD_KEY=replace-with-a-long-random-secret

# Optional but useful if you want a true zero-guild state on first boot.
# Leave unset or set to 1 to auto-create /guild on startup.
# SEED_DEFAULT_GUILD=0

# Default DB path is already /opt/guild/server/data/messenger.db when deployed
# with the layout in ops/flokinet/README.md. Leave this commented unless you
# want to move the DB elsewhere.
# DB_PATH=/opt/guild/server/data/messenger.db
