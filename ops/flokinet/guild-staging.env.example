NODE_ENV=production
PORT=3002

# Required for mediasoup clients outside localhost.
ANNOUNCED_IP=203.0.113.10

# Use a staging-only hostname so test clients never hit production by mistake.
ALLOWED_ORIGINS=https://staging.guild.app

# Keep staging on its own RTP range so it can share the same host as production.
MEDIASOUP_RTC_MIN_PORT=10101
MEDIASOUP_RTC_MAX_PORT=10200

# Optional: raise if your staging screen-share tests need more headroom.
# MEDIASOUP_INITIAL_OUTGOING_BITRATE=10000000

# Required before exposing the dev dashboard anywhere beyond localhost.
DEV_DASHBOARD_KEY=replace-with-a-different-long-random-secret

# Optional: keep staging isolated from auto-seeding if you want a blank state.
# Leave unset or set to 1 to auto-create /guild on startup.
# SEED_DEFAULT_GUILD=0

# Optional: enable native HTTPS directly in the Node server.
# If you terminate TLS at Caddy or another reverse proxy, leave these unset.
# TLS_KEY_PATH=/etc/ssl/private/guild-staging.key
# TLS_CERT_PATH=/etc/ssl/certs/guild-staging.crt
# TLS_CA_PATH=/etc/ssl/certs/guild-staging-chain.crt
# HTTP_REDIRECT_PORT=8080

# Staging keeps its own DB by default under /opt/guild-staging/server/data.
# DB_PATH=/opt/guild-staging/server/data/messenger.db
