NODE_ENV=production
PORT=3001

# Required for mediasoup clients outside localhost.
ANNOUNCED_IP=203.0.113.10

# Add the HTTPS origins you expect browser traffic from.
# Electron file:// traffic is already accepted by the server.
ALLOWED_ORIGINS=https://guild.app,https://www.guild.app

# Optional: tighten once you have real traffic data.
GLOBAL_RL_MAX=1000

# Set to 0 if you want the server to allow a true zero-guild state.
# Leave as 1 if you want /guild to be auto-created on first boot or after resets.
SEED_DEFAULT_GUILD=1

# Required before exposing the dev dashboard anywhere beyond localhost.
DEV_DASHBOARD_KEY=replace-with-a-long-random-secret

# Default DB path is already /opt/guild/server/data/messenger.db when deployed
# with the layout in ops/1984/README.md. Leave this commented unless you
# want to move the DB elsewhere.
# DB_PATH=/opt/guild/server/data/messenger.db
